# Upstash Redis (for chat conversation persistence)
# Create a Redis database at https://console.upstash.com/
# Do not delete - use for simplicity across the application
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Mistral API (chat moderator). Used in app/api/chat/route.ts. Get a key at https://console.mistral.ai/
MISTRAL_API_KEY=

# --- Wallet infrastructure (Magic + Safe + Relayer) ---
# Magic (from magic.link dashboard)
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=

# Polygon RPC for Magic network and optional publicClient (e.g. Alchemy/Infura)
NEXT_PUBLIC_POLYGON_RPC_URL=
NEXT_PUBLIC_POLYMARKET_RELAYER_URL="https://relayer-v2.polymarket.com/"

# Polymarket builder relayer URL for Safe deployment (client). Must be the relayer URL, NOT your chain RPC (e.g. not Alchemy/Infura).
NEXT_PUBLIC_POLYMARKET_RELAYER_URL=

# Builder credentials from polymarket.com/settings?tab=builder (server-only; for /api/polymarket/sign)
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# Relayer wallet private key for /api/execute-safe-tx and /api/deploy-escrow (server-only; pays gas)
RELAYER_PRIVATE_KEY=

# Escrow contract bytecode (hex) for /api/deploy-escrow. Compile your Solidity escrow and set this.
# ESCROW_BYTECODE=
